# 数据库连接字符串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wut_self_study?schema=public"

# NextAuth 配置 (运行 `npx auth secret` 生成)
AUTH_SECRET="your-generated-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# 上传文件大小限制 (MB)
MAX_FILE_SIZE_MB=50

# Railway Volume mount path example
STORAGE_ROOT="/data/storage"
