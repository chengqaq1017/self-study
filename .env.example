# Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wut_self_study?schema=public"

# NextAuth configuration
AUTH_SECRET="your-generated-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Optional seed admin. Leave blank to avoid creating a default admin account.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Upload file size limit in MB. Keep both values the same.
MAX_FILE_SIZE_MB=200
NEXT_PUBLIC_MAX_FILE_SIZE_MB=200

# Railway Volume mount path example
STORAGE_ROOT="/data/storage"
