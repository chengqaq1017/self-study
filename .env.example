# Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wut_self_study?schema=public"

# NextAuth configuration
AUTH_SECRET="your-generated-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Optional seed admin. Leave blank to avoid creating a default admin account.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Upload file size limit in MB. Keep both values the same.
# IMPORTANT: during upload, the file appears 3-4× in memory (FormData →
# ArrayBuffer → Buffer). So effective peak memory = file_size × 3.5.
# With MAX_HEAP_MB=256, 50MB is a safe ceiling.
MAX_FILE_SIZE_MB=50
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50

# Railway Volume mount path example
STORAGE_ROOT="/data/storage"

# Node.js heap memory limit in MB. Smaller values reduce memory footprint
# at the cost of GC frequency. 256 is appropriate for a low-traffic campus site.
MAX_HEAP_MB=256

# PostgreSQL connection pool size. Each connection adds ~5-10 MB of memory.
# Default 5 is plenty for a small site; reduce further if memory is tight.
DB_POOL_MAX=5

# libuv thread pool size. Default 4; 2 saves a little memory for I/O-bound apps.
UV_THREADPOOL_SIZE=2
